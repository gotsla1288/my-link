rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // users/{userId} (프로필 정보 문서)
    match /users/{userId} {
      // 읽기: 누구나 가능 (비로그인 방문자 허용)
      allow read: if true;
      
      // 쓰기(생성/수정/삭제): 로그인 필수 및 본인 데이터만 허용
      // - 로그인한 유저의 UID가 userId 경로와 같거나
      // - 구글 이메일의 ID 앞부분이 userId 경로와 같을 때 수정 가능
      allow write: if request.auth != null && (
        request.auth.uid == userId || 
        (request.auth.token.email != null && request.auth.token.email.matches(userId + "@.*"))
      );
      
      // users/{userId}/links/{linkId} (링크 목록 문서) 규칙
      match /links/{linkId} {
        // 읽기: 누구나 가능 (외부 공개)
        allow read: if true;
        
        // 쓰기: 본인 데이터만 수정 가능
        allow write: if request.auth != null && (
          request.auth.uid == userId || 
          (request.auth.token.email != null && request.auth.token.email.matches(userId + "@.*"))
        );
      }
    }
  }
}
